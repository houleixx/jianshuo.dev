# Copy to `.env` on the VPS (chmod 600). Loaded by systemd EnvironmentFile.

# Claude subscription OAuth token — run `claude setup-token` locally and paste here.
# Using the subscription token keeps this on your plan (no API billing) but is
# for SINGLE-USER personal use only (Anthropic ToS). To share / go multi-user,
# replace this line with ANTHROPIC_API_KEY=sk-ant-... instead.
CLAUDE_CODE_OAUTH_TOKEN=

PORT=8787
HOST=127.0.0.1
MODEL=claude-opus-4-8
WORKSPACE=/opt/claude-agent/workspace
MAX_TURNS=30
