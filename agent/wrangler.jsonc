{
  // VoiceDrop article-editing Agent. Separate Worker (Pages can't host Durable
  // Objects). Bound to the SAME R2 bucket as the jianshuo.dev Pages project and
  // shares SESSION_SECRET so it can authenticate the app's existing tokens.
  "name": "voicedrop-agent",
  "main": "src/index.js",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],

  // Take over only the /agent/* path on the zone; Pages still serves everything
  // else → same-origin wss://jianshuo.dev/agent/...
  "routes": [
    { "pattern": "jianshuo.dev/agent/*", "zone_name": "jianshuo.dev" }
  ],

  "r2_buckets": [
    { "binding": "FILES", "bucket_name": "jianshuo-dev-files" }
  ],

  "durable_objects": {
    "bindings": [
      { "name": "ArticleEditor", "class_name": "ArticleEditor" },
      { "name": "StatusHub",     "class_name": "StatusHub"     },
      { "name": "Miner",         "class_name": "Miner"         }
    ]
  },

  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ArticleEditor"] },
    { "tag": "v2", "new_sqlite_classes": ["StatusHub"] },
    { "tag": "v3", "new_sqlite_classes": ["Miner"] }
  ],

  "triggers": {
    "crons": ["0 */6 * * *"]
  }

  // Secrets (set with `wrangler secret put`):
  //   SESSION_SECRET         — same value as the Pages project
  //   CLAUDE_API_KEY         — Anthropic API key
  //   FILES_TOKEN            — admin token for jianshuo.dev/files
  //   VOLC_ASR_APPID         — Volcano ASR app id       (was GitHub secret)
  //   VOLC_ASR_ACCESS_TOKEN  — Volcano ASR access token (was GitHub secret)
  //   R2_ACCOUNT_ID          — Cloudflare account id    (was GitHub secret)
  //   R2_ACCESS_KEY_ID       — R2 S3 access key         (was GitHub secret)
  //   R2_SECRET_ACCESS_KEY   — R2 S3 secret key         (was GitHub secret)
}
